# Foraya — Ayu base + Gruvbox/Everforest accents (contrast={{ meta.contrast }}, accent={{ meta.accent }})
# KDE/Qt (KConfig) color scheme, consumed by kdeglobals' [General] ColorScheme=Foraya.
# Applies to Dolphin and any other KDE Frameworks app on this system.

[ColorEffects:Disabled]
Color={{ neutral.dim | hexrgb }}
ColorAmount=0
ColorEffect=0
ContrastAmount=0.65
ContrastEffect=0
IntensityAmount=0.1
IntensityEffect=2

[ColorEffects:Inactive]
ChangeSelectionColor=true
Color={{ neutral.mid | hexrgb }}
ColorAmount=0.025
ColorEffect=2
ContrastAmount=0.1
ContrastEffect=2
Enable=false
IntensityAmount=0
IntensityEffect=0

