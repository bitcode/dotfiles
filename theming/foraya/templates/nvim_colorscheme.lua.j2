-- Foraya colorscheme (contrast={{ meta.contrast }}, accent={{ meta.accent }})
-- Generated by theming/foraya/generate.py — do not hand-edit, edit
-- theming/foraya/palette.yml and regenerate instead.
-- nvim auto-discovers colors/*.lua on runtimepath: `:colorscheme foraya`

vim.cmd("hi clear")
if vim.fn.exists("syntax_on") then
  vim.cmd("syntax reset")
end
vim.o.termguicolors = true
vim.g.colors_name = "foraya"

local p = require("foraya.palette")
local bg, fg, neutral, accents, special = p.bg, p.fg, p.neutral, p.accents, p.special

local hl = function(group, opts)
  vim.api.nvim_set_hl(0, group, opts)
end

-- Editor UI
hl("Normal", { fg = fg.primary, bg = bg.base })
hl("NormalFloat", { fg = fg.primary, bg = bg.popup })
hl("NormalNC", { fg = fg.primary, bg = bg.base })
hl("CursorLine", { bg = bg.line })
hl("CursorLineNr", { fg = accents.yellow, bold = true })
hl("LineNr", { fg = neutral.dim })
hl("SignColumn", { bg = bg.base })
hl("ColorColumn", { bg = bg.line })
hl("Cursor", { fg = bg.base, bg = special.gold })
hl("Visual", { bg = bg.gutter })
hl("VisualNOS", { bg = bg.gutter })
hl("Search", { fg = bg.base, bg = accents.yellow })
hl("IncSearch", { fg = bg.base, bg = accents.orange })
hl("MatchParen", { fg = special.gold, bold = true })
hl("Pmenu", { fg = fg.primary, bg = bg.panel })
hl("PmenuSel", { fg = bg.base, bg = special.gold })
hl("PmenuSbar", { bg = bg.gutter })
hl("PmenuThumb", { bg = neutral.mid })
hl("StatusLine", { fg = fg.primary, bg = bg.panel })
hl("StatusLineNC", { fg = neutral.dim, bg = bg.panel })
hl("TabLine", { fg = neutral.dim, bg = bg.panel })
hl("TabLineFill", { bg = bg.panel })
hl("TabLineSel", { fg = fg.primary, bg = bg.lift })
hl("VertSplit", { fg = bg.gutter })
hl("WinSeparator", { fg = bg.gutter })
hl("FloatBorder", { fg = neutral.mid, bg = bg.popup })
hl("Title", { fg = accents.green, bold = true })
hl("Directory", { fg = accents.blue })
hl("ErrorMsg", { fg = accents.red, bold = true })
hl("WarningMsg", { fg = accents.orange, bold = true })
hl("ModeMsg", { fg = fg.primary })
hl("MoreMsg", { fg = accents.green })
hl("Question", { fg = accents.green })

-- Syntax
hl("Comment", { fg = fg.dim, italic = true })
hl("Constant", { fg = special.gold })
hl("String", { fg = accents.green })
hl("Character", { fg = accents.green })
hl("Number", { fg = special.gold })
hl("Boolean", { fg = special.gold })
hl("Float", { fg = special.gold })
hl("Identifier", { fg = accents.blue })
hl("Function", { fg = accents.yellow, bold = true })
hl("Statement", { fg = accents.red })
hl("Conditional", { fg = accents.red })
hl("Repeat", { fg = accents.red })
hl("Label", { fg = accents.red })
hl("Operator", { fg = fg.primary })
hl("Keyword", { fg = accents.red })
hl("Exception", { fg = accents.red })
hl("PreProc", { fg = accents.purple })
hl("Include", { fg = accents.purple })
hl("Define", { fg = accents.purple })
hl("Macro", { fg = accents.purple })
hl("PreCondit", { fg = accents.purple })
hl("Type", { fg = accents.yellow })
hl("StorageClass", { fg = accents.yellow })
hl("Structure", { fg = accents.yellow })
hl("Typedef", { fg = accents.yellow })
hl("Special", { fg = accents.aqua })
hl("SpecialChar", { fg = accents.aqua })
hl("Tag", { fg = accents.aqua })
hl("Delimiter", { fg = neutral.bright })
hl("SpecialComment", { fg = neutral.mid, italic = true })
hl("Debug", { fg = accents.red })
hl("Underlined", { underline = true })
hl("Ignore", { fg = neutral.dim })
hl("Error", { fg = accents.red, bold = true })
hl("Todo", { fg = bg.base, bg = accents.yellow, bold = true })

-- Diff
hl("DiffAdd", { fg = special.vcs.added, bg = bg.line })
hl("DiffChange", { fg = special.vcs.modified, bg = bg.line })
hl("DiffDelete", { fg = special.vcs.removed, bg = bg.line })
hl("DiffText", { fg = fg.primary, bg = bg.gutter })

-- Diagnostics
hl("DiagnosticError", { fg = accents.red })
hl("DiagnosticWarn", { fg = accents.orange })
hl("DiagnosticInfo", { fg = special.info })
hl("DiagnosticHint", { fg = special.hint })
hl("DiagnosticUnderlineError", { undercurl = true, sp = accents.red })
hl("DiagnosticUnderlineWarn", { undercurl = true, sp = accents.orange })
hl("DiagnosticUnderlineInfo", { undercurl = true, sp = special.info })
hl("DiagnosticUnderlineHint", { undercurl = true, sp = special.hint })

-- gitsigns.nvim
hl("GitSignsAdd", { fg = special.vcs.added })
hl("GitSignsChange", { fg = special.vcs.modified })
hl("GitSignsDelete", { fg = special.vcs.removed })

-- Telescope
hl("TelescopeNormal", { fg = fg.primary, bg = bg.popup })
hl("TelescopeBorder", { fg = neutral.mid, bg = bg.popup })
hl("TelescopeSelection", { fg = fg.primary, bg = bg.gutter, bold = true })
hl("TelescopePromptNormal", { fg = fg.primary, bg = bg.panel })
hl("TelescopePromptBorder", { fg = neutral.mid, bg = bg.panel })

-- LSP
hl("LspReferenceText", { bg = bg.gutter })
