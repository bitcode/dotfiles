# i3blocks config file
#
# Please see man i3blocks for a complete reference!
# The man page is also hosted at http://vivien.github.io/i3blocks
#
# List of valid properties:
#
# align
# color
# command
# full_text
# instance
# interval
# label
# min_width
# name
# separator
# separator_block_width
# short_text
# signal
# urgent

# Global properties
#
# The top properties below are applied to every block, but can be overridden.
# Each block command defaults to the script name to avoid boilerplate.
# Change $SCRIPT_DIR to the location of your scripts!
command=$SCRIPT_DIR/$BLOCK_NAME
separator_block_width=18
markup=pango


######################################################################################
# Foraya color theme (contrast={{ meta.contrast }}, accent={{ meta.accent }})
# See theming/foraya/palette.yml ‚ÄĒ regenerate via theming/foraya/generate.py
######################################################################################

[memory]
command=~/dotfiles/i3blocks/.config/i3blocks/scripts/memory/memory
label=ůįćõ
interval=30
color={{ neutral.bright }}

[temperature]
command=~/dotfiles/i3blocks/.config/i3blocks/scripts/temperature/temperature
label=
color={{ accents.aqua }}
interval=10
#T_WARN=70
#T_CRIT=90
#SENSOR_CHIP=""

[cpu_usage]
command=~/dotfiles/i3blocks/.config/i3blocks/scripts/cpu_usage/cpu_usage
interval=10
label=
#color=#8bd5ca
#min_width=CPU: 100.00%
#T_WARN=50
#T_CRIT=80
#DECIMALS=2
#COLOR_NORMAL=#EBDBB2
#COLOR_WARN=#FFFC00
#COLOR_CRIT=#FF0000

[jas]
command=~/dotfiles/i3blocks/.config/i3blocks/scripts/jas/jas
color={{ accents.yellow }}
label=ůįÉü
markup=pango
interval=once
signal=10
#STEP_SIZE=5

[baterkos]
command=~/dotfiles/i3blocks/.config/i3blocks/scripts/battery/battery
interval=10
label= 
color={{ accents.green }}

[spotify]
label=
command=python3 ~/dotfiles/i3blocks/.config/i3blocks/scripts/spotify/spotify.py
color={{ accents.aqua }}
interval=5

[volume]
command=~/dotfiles/i3blocks/.config/i3blocks/scripts/volume/volume
label=ůįēĺ
interval=1
signal=10
color={{ accents.purple }}
markup=pango

#[mediaplayer]
# This picks any player, with vlc as first, and spotify as last choice
#command=$SCRIPT_DIR/mediaplayer/mediaplayer
#instance=spotify
#label=
#color=#c6a0f6
#interval=5
#signal=10

# Date Time
[time]
command=date '+%A %d.%m. %H:%M:%S'
label=ůįÉį
interval=1
color={{ fg.primary }}

# Rofi baii
[shutdown_menu]
full_text=
command=~/dotfiles/i3blocks/.config/i3blocks/scripts/shutdown_menu/shutdown_menu
min_width=16
color={{ accents.red }}

[separator]
full_text=" "

####################################################################################
