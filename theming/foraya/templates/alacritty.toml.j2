# Foraya — Ayu base + Gruvbox/Everforest accents (contrast={{ meta.contrast }}, accent={{ meta.accent }})
# See theming/foraya/palette.yml

[colors.primary]
background = "{{ bg.base }}"
foreground = "{{ fg.primary }}"

[colors.cursor]
cursor = "{{ cursor.color }}"
text = "{{ cursor.text }}"

[colors.selection]
background = "{{ selection.background }}"
text = "{{ selection.foreground }}"

[colors.normal]
black   = "{{ bg.lift }}"
red     = "{{ accents.red }}"
green   = "{{ accents.green }}"
yellow  = "{{ accents.yellow }}"
blue    = "{{ accents.blue }}"
magenta = "{{ accents.purple }}"
cyan    = "{{ accents.cyan }}"
white   = "{{ neutral.bright }}"

[colors.bright]
black   = "{{ bg.gutter }}"
red     = "{{ accents.red }}"
green   = "{{ accents.green }}"
yellow  = "{{ accents.yellow }}"
blue    = "{{ accents.blue }}"
magenta = "{{ accents.purple }}"
cyan    = "{{ accents.cyan }}"
white   = "{{ fg.primary }}"
