# ~/.config/starship.toml
# Foraya color theme (contrast={{ meta.contrast }}, accent={{ meta.accent }})
# See theming/foraya/palette.yml — regenerate via theming/foraya/generate.py

# Get editor completions based on the config schema
"$schema" = 'https://starship.rs/config-schema.json'

# Inserts a blank line between shell prompts
add_newline = false

# Username module configuration
[username]
style_user = "bold {{ accents.yellow }}"
disabled = false

# Hostname module configuration
[hostname]
ssh_only = true
style = "bold dimmed {{ accents.blue }}"
disabled = false

# Directory module configuration
[directory]
truncation_length = 3
truncate_to_repo = false
style = "bold {{ accents.cyan }}"
disabled = false

# Git branch module configuration
[git_branch]
symbol = " "
style = "bold {{ accents.purple }}"
disabled = false

# Git status module configuration
[git_status]
style = "bold {{ accents.red }}"
disabled = false

# Package module configuration
[package]
disabled = true

# NodeJS module configuration
[nodejs]
symbol = "⬢ "
style = "bold {{ accents.green }}"
disabled = false

# Python module configuration
[python]
symbol = "🐍 "
style = "bold {{ accents.blue }}"
disabled = false

# Jobs module configuration
[jobs]
threshold = 1
symbol = "⚙️ "
style = "bold {{ accents.red }}"
disabled = false

# Character module configuration
[character]
success_symbol = "[➜](bold {{ accents.green }})"
error_symbol = "[✗](bold {{ accents.red }})"
vicmd_symbol = "[❮](bold {{ accents.purple }})"
disabled = false
